{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/src/index.js" },
    { "source": "/assets/(.*)", "destination": "frontend/dist/assets/$1" },
    { "source": "/(.*)", "destination": "frontend/dist/index.html" }
  ]
}