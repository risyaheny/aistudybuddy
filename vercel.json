{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    { "source": "/api/(.*)", "destination": "backend/src/index.js" },
    { "handle": "filesystem" },
    { "source": "/(.*)", "destination": "frontend/index.html" }
  ]
}